<?xml version="1.0" encoding="utf-8"?>
<project xmlns="http://lime.openfl.org/project/1.0.4" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns:android="http://schemas.android.com/apk/res/android"
         xmlns:config="http://lime.openfl.org/project/config"
         xsi:schemaLocation="http://lime.openfl.org/project/1.0.4 http://lime.openfl.org/xsd/project-1.0.4.xsd">

	<!-- _________________________ Application Settings _________________________ -->

	<app title="I Wanna Be The Flixel v.020 Test" file="IWBTF" main="Main" version="0.20" company="darkuganda" package="com.darkuganda.iwbtf"/>
	<certificate path="release.keystore" alias="release" password="123456" if="android" />
	<set name="ANDROID_NDK_ROOT" value="C:\Users\darku\AppData\Local\Android\Sdk\ndk\21.4.7075529" force="true" />
	<set name="no-debug" value="1" />
	<set name="debug" value="false" unless="debug" />
	<set name="ANDROID_DEBUGGABLE" value="false" />
	<haxedef name="no_debug" />

	<icon path="assets/images/shared/icon.png" if="windows"/>
	<icon path="assets/images/shared/icon-mobile.png" if="android"/>

	<!--The flixel preloader is not accurate in Chrome. You can use it regularly if you embed the swf into a html file
		or you can set the actual size of your file manually at "FlxPreloaderBase-onUpdate-bytesTotal"-->
	<app preloader="flixel.system.FlxPreloader" />

	<!--Minimum without FLX_NO_GAMEPAD: 11.8, without FLX_NO_NATIVE_CURSOR: 11.2-->
	<set name="SWF_VERSION" value="11.8" />

	<!-- ____________________________ Window Settings ___________________________ -->

	<!--These window settings apply to all targets-->
	<window width="1280" height="720" fps="240" background="#000000" hardware="true" vsync="true" />

	<!--HTML5-specific-->
	<window if="html5" resizable="true" />

	<!--Desktop-specific-->
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" />

	<!--Mobile-specific-->
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" />

	<!-- _____________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="export" />
	<source path="source" />

	<assets path="assets/data" embed="true"/>
	<assets path="assets/debug" embed="true"/>

	<assets path="assets/images/shared"/>
	<assets path="assets/images/backgrounds"/>
	<assets path="assets/images/title"/>
	<assets path="assets/images/skins" embed="true"/>
	<assets path="assets/images/levels" embed="true"/>
	<assets path="assets/images/foreground" embed="true"/>
	<assets path="assets/images/bosses" embed="true"/>
	<assets path="assets/music"/>
	<assets path="assets/sounds"/>
	
	<template path="templates" />
	<set name="KEYSTORE_FILE" value="../../release.keystore" />
	<!-- _______________________________ Libraries ______________________________ -->

	<haxelib name="flixel" />
	<haxelib name="flixel-addons" />

	<haxelib name="flixel-ui" />

	<!--In case you want to use nape with flixel-->
	<!--<haxelib name="nape-haxe4" />-->

	<!-- ______________________________ Haxedefines _____________________________ -->

	<!--Remove the legacy health system-->
	<haxedef name="FLX_NO_HEALTH" />
	
	<!--Enable the Flixel core recording system-->
	<!--<haxedef name="FLX_RECORD" />-->

	<!--Disable the right and middle mouse buttons-->
	<!--<haxedef name="FLX_NO_MOUSE_ADVANCED" />-->

	<!--Optimise inputs, be careful you will get null errors if you don't use conditionals in your game-->
	<haxedef name="FLX_NO_MOUSE" if="mobile" />
	<haxedef name="FLX_NO_KEYBOARD" if="mobile" />
	<haxedef name="FLX_NO_TOUCH" if="desktop" />
	<!--<haxedef name="FLX_NO_GAMEPAD" />-->

	<!--Disable the Flixel core sound tray-->
	<!--<haxedef name="FLX_NO_SOUND_TRAY" />-->

	<!--Disable the Flixel sound management code-->
	<!--<haxedef name="FLX_NO_SOUND_SYSTEM" />-->

	<!--Disable the Flixel core focus lost screen-->
	<!--<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />-->

	<!--Disable the Flixel core debugger. Automatically gets set whenever you compile in release mode!-->
	<!--Enable this for Nape release builds for a serious peformance improvement-->
	<haxedef name="FLX_NO_DEBUG" if="release" />
	<haxedef name="FLX_NO_MOUSE_ADVANCED" if="mobile" />
	<haxedef name="no_debug" if="release" />

	<haxedef name="fdb" value="0" />
	<!-- Haxe 4.3.0+: Enable pretty syntax errors and stuff. -->
	<!-- pretty (haxeflixel default), indent, classic (haxe compiler default) -->
	<haxedef name="message.reporting" value="pretty" />

	<!-- _________________________________ Custom _______________________________ -->

	<haxedef name="no_pch" />
</project>
